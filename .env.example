# --- Database ---
DATABASE_URL=postgresql+asyncpg://dealscout:dealscout_secret@localhost:5432/dealscout
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
# Primary: Groq (free tier, high speed)
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama3-70b-8192

# Fallback: OpenAI
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# --- Affiliate Networks ---
AMAZON_ASSOCIATES_TAG=dealscout-21
EBAY_PARTNER_NETWORK_ID=your_ebay_id
AWIN_API_KEY=your_awin_key
AWIN_PUBLISHER_ID=your_awin_publisher
ADMITAD_API_KEY=your_admitad_key
IMPACT_API_KEY=your_impact_key
RAKUTEN_API_KEY=your_rakuten_key

# --- Social Media ---
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@your_channel

FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_token
FACEBOOK_PAGE_ID=your_facebook_page_id

INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

PINTEREST_ACCESS_TOKEN=your_pinterest_token
PINTEREST_BOARD_ID=your_board_id

# --- Blog ---
WORDPRESS_URL=https://yourblog.com
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=your_app_password

# --- Reddit ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=DealScoutAI/0.1

# --- Newsletter ---
MAILCHIMP_API_KEY=your_mailchimp_key
MAILCHIMP_LIST_ID=your_list_id

# --- Proxy ---
PROXY_LIST=http://proxy1:8080,http://proxy2:8080
PROXY_ROTATE_INTERVAL=300

# --- Scraping ---
MAX_CONCURRENT_SCRAPES=5
SCRAPE_FREQUENCY_HOURS=6
REQUEST_TIMEOUT=30
USER_AGENT_ROTATE=true

# --- Deal Filtering ---
MIN_DISCOUNT_PERCENT=20
MAX_DEAL_AGE_DAYS=30
PRICE_HISTORY_DAYS=30

# --- Output ---
LOG_LEVEL=INFO
DATA_DIR=./data
